#!/usr/bin/env bash

STATE_DIR="${XDG_RUNTIME_DIR:-${XDG_STATE_HOME:-$HOME/.local/state}}/tiny-dictate"
REC_FILE="$STATE_DIR/tiny-dictate.mp3"
REC_PIDFILE="$STATE_DIR/arecord.pid"
WORKER_PIDFILE="$STATE_DIR/worker.pid"
SPINNER_PIDFILE="$STATE_DIR/spinner.pid"
NOTIFY_IDFILE="$STATE_DIR/notification.id"

mkdir -p "$STATE_DIR"

require_commands() {
    local missing=()
    local cmd

    for cmd in "$@"; do
        if ! command -v "$cmd" >/dev/null 2>&1; then
            missing+=("$cmd")
        fi
    done

    if [ "${#missing[@]}" -gt 0 ]; then
        printf 'Missing dependencies: %s\n' "${missing[*]}" >&2
        return 1
    fi
}

format_error_message() {
    local error_text="$1"
    local single_line

    single_line="$(printf '%s' "$error_text" | tr '\n' ' ' | sed -E 's/[[:space:]]+/ /g; s/^ //; s/ $//')"
    if [ -z "$single_line" ]; then
        printf 'Unknown error'
        return
    fi

    printf '%.180s' "$single_line"
}

notify_init() {
    NOTIFY_APP_NAME="$1"
    NOTIFY_IDFILE="$2"
}

notify_message() {
    local message="$1"
    local timeout="${2:-0}"
    local urgency="${3:-normal}"
    local args=(--printid --appname "$NOTIFY_APP_NAME" --urgency "$urgency" --timeout "$timeout")
    local notify_id

    if [ -f "$NOTIFY_IDFILE" ]; then
        args+=(--replace "$(cat "$NOTIFY_IDFILE")")
    fi

    notify_id="$(dunstify "${args[@]}" "$NOTIFY_APP_NAME" "$message")" || return 1
    printf '%s' "$notify_id" > "$NOTIFY_IDFILE"
}

close_notification() {
    if [ -f "$NOTIFY_IDFILE" ]; then
        dunstify --close="$(cat "$NOTIFY_IDFILE")" >/dev/null 2>&1 || true
        rm -f "$NOTIFY_IDFILE"
    fi
}

start_spinner() {
    local label="$1"

    stop_spinner

    (
        local frames=('⠋' '⠙' '⠹' '⠸' '⠼' '⠴' '⠦' '⠧' '⠇' '⠏')
        local i=0

        while true; do
            notify_message "$label ${frames[$i]}" || true
            i=$(( (i + 1) % ${#frames[@]} ))
            sleep 0.15
        done
    ) &

    SPINNER_PID=$!
}

stop_spinner() {
    if [ -n "${SPINNER_PID:-}" ] && kill -0 "$SPINNER_PID" 2>/dev/null; then
        kill "$SPINNER_PID" 2>/dev/null || true
        wait "$SPINNER_PID" 2>/dev/null || true
    fi
    SPINNER_PID=""
}

detect_clipboard_tool() {
    if command -v wl-copy >/dev/null 2>&1 && command -v wl-paste >/dev/null 2>&1; then
        CLIPBOARD_TOOL="wl-clipboard"
        return 0
    fi
    return 1
}

clipboard_write_clipboard() {
    local value="$1"
    printf '%s' "$value" | wl-copy
}

clipboard_write_primary() {
    local value="$1"
    printf '%s' "$value" | wl-copy --primary
}

clipboard_write_both() {
    local value="$1"
    clipboard_write_clipboard "$value"
    clipboard_write_primary "$value"
}

clipboard_paste_via_shift_insert() {
    local value="$1"
    local hold_delay="${LLM_SHIFT_INSERT_HOLD_DELAY_SEC:-0.04}"
    local key_status=0

    clipboard_write_both "$value"

    # ydotool uses Linux input keycodes: 42=LeftShift, 110=Insert.
    ydotool key 42:1 || return 1
    sleep "$hold_delay"
    ydotool key 110:1 110:0 || key_status=$?
    sleep "$hold_delay"
    ydotool key 42:0 || true

    return "$key_status"
}

notify_init "tiny-dictate" "$NOTIFY_IDFILE"

is_running_pidfile() {
    local pidfile="$1"

    if [ ! -f "$pidfile" ]; then
        return 1
    fi

    kill -0 "$(cat "$pidfile")" 2>/dev/null
}

recording_active() {
    if is_running_pidfile "$REC_PIDFILE"; then
        return 0
    fi

    rm -f "$REC_PIDFILE"
    return 1
}

kill_from_pidfile() {
    local pidfile="$1"
    local signal="$2"

    if is_running_pidfile "$pidfile"; then
        kill "$signal" "$(cat "$pidfile")" 2>/dev/null
    fi

    rm -f "$pidfile"
}

stop_spinner_with_pidfile() {
    if [ -z "${SPINNER_PID:-}" ] && [ -f "$SPINNER_PIDFILE" ]; then
        SPINNER_PID="$(cat "$SPINNER_PIDFILE")"
    fi
    stop_spinner
    rm -f "$SPINNER_PIDFILE"
}

start_spinner_with_pidfile() {
    start_spinner "$1"
    if [ -n "${SPINNER_PID:-}" ]; then
        printf '%s' "$SPINNER_PID" > "$SPINNER_PIDFILE"
    fi
}

microphone_is_muted() {
    local output
    local control

    if command -v wpctl >/dev/null 2>&1; then
        output="$(wpctl get-volume @DEFAULT_AUDIO_SOURCE@ 2>/dev/null || true)"
        if [ -n "$output" ]; then
            printf '%s' "$output" | grep -q '\[MUTED\]' && return 0
            return 1
        fi
    fi

    if command -v pactl >/dev/null 2>&1; then
        output="$(pactl get-source-mute @DEFAULT_SOURCE@ 2>/dev/null || true)"
        case "$output" in
            *"Mute: yes"*) return 0 ;;
            *"Mute: no"*) return 1 ;;
        esac
    fi

    if command -v amixer >/dev/null 2>&1; then
        for control in Capture Mic; do
            output="$(amixer -D default sget "$control" 2>/dev/null || true)"
            if [ -n "$output" ]; then
                printf '%s' "$output" | grep -q '\[on\]' && return 1
                printf '%s' "$output" | grep -q '\[off\]' && return 0
            fi
        done
    fi

    return 1
}

ensure_micro_not_muted() {
    if microphone_is_muted; then
        notify_message "🎙️ Microphone is muted. Unmute it before dictating." 4500 critical || true
        return 1
    fi

    return 0
}

start() {
    ensure_micro_not_muted || return 1

    rm -f "$REC_FILE"

    start_spinner_with_pidfile "🎤 Recording"

    { arecord -f S16_LE -r 16000 -c 1 -t raw - & echo $! > "$REC_PIDFILE"; wait; } \
        | lame -r -s 16 --bitwidth 16 --signed --little-endian -m m -b 64 -S - "$REC_FILE" &

    (
        local transcript
        local transcribe_err_file
        local transcribe_err_msg
        local had_error=0

        cleanup_worker() {
            [ -n "${transcribe_err_file:-}" ] && rm -f "$transcribe_err_file"
            rm -f "$REC_FILE"
            stop_spinner_with_pidfile
        }
        trap cleanup_worker EXIT

        # Wait for recording to finish
        while is_running_pidfile "$REC_PIDFILE"; do
            sleep 0.1
        done

        start_spinner_with_pidfile "⏳ Transcribing"

        transcribe_err_file="$(mktemp "$STATE_DIR/transcribe.XXXXXX.err")"

        if transcript="$(llm groq-whisper - < "$REC_FILE" 2>"$transcribe_err_file")"; then
            if [ -n "$transcript" ]; then
                clipboard_paste_via_shift_insert "$transcript"
            fi
        else
            had_error=1
            stop_spinner_with_pidfile
            transcribe_err_msg="$(format_error_message "$(cat "$transcribe_err_file")")"
            notify_message "❌ Transcription failed: $transcribe_err_msg" 6000
        fi

        rm -f "$transcribe_err_file"
        stop_spinner_with_pidfile
        if [ "$had_error" -eq 0 ]; then
            close_notification
        fi
        rm -f "$WORKER_PIDFILE"
    ) &
    echo $! > "$WORKER_PIDFILE"
}

stop() {
    if recording_active; then
        kill_from_pidfile "$REC_PIDFILE" -INT
    fi
}

cancel() {
    if ! recording_active; then
        echo "No recording in progress"
        return 0
    fi

    kill_from_pidfile "$WORKER_PIDFILE" -TERM
    kill_from_pidfile "$REC_PIDFILE" -INT
    stop_spinner_with_pidfile
    notify_message "🛑 Recording cancelled" 1000
    (sleep 1; close_notification) & disown
}

toggle() {
    if recording_active; then
        stop
    else
        start
    fi
}

status() {
    if recording_active || is_running_pidfile "$WORKER_PIDFILE"; then
        echo "working"
    else
        echo "idle"
    fi
}

usage() {
    cat <<'EOF'
Usage: tiny-dictate <command>

Commands:
  start   Start recording
  stop    Stop recording and transcribe
  cancel  Cancel recording
  toggle  Start if idle, stop if recording
  status  Show status (idle or working)
EOF
}

if ! require_commands arecord lame llm ydotool dunstify; then
    dunstify --appname "tiny-dictate" --timeout 6000 "tiny-dictate" "❌ Missing dependencies" >/dev/null 2>&1 || true
    printf 'Install the missing commands and retry.\n' >&2
    exit 1
fi

if ! detect_clipboard_tool; then
    printf 'Missing dependencies: wl-copy and wl-paste\n' >&2
    dunstify --appname "tiny-dictate" --timeout 6000 "tiny-dictate" "❌ Missing dependencies: wl-copy and wl-paste" >/dev/null 2>&1 || true
    printf 'Install wl-clipboard and retry.\n' >&2
    exit 1
fi

command=""

while [ "$#" -gt 0 ]; do
    case "$1" in
        start|stop|cancel|toggle|status)
            if [ -n "$command" ]; then
                echo "Only one command can be provided" >&2
                exit 1
            fi
            command="$1"
            ;;
        -h|--help|help)
            command="help"
            ;;
        *)
            echo "Unknown argument: $1" >&2
            usage
            exit 1
            ;;
    esac
    shift
done

case "$command" in
    start)
        start
        ;;
    stop)
        stop
        ;;
    cancel)
        cancel
        ;;
    toggle)
        toggle
        ;;
    status)
        status
        ;;
    ""|help)
        usage
        ;;
    *)
        usage
        exit 1
        ;;
esac
