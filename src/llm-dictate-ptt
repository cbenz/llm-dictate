#!/usr/bin/env bash
# Push-to-talk variant: bind `start` to key press and `stop` to key release.
#
# Example sway/i3 bindings:
#   bindsym XF86Launch5 exec llm-dictate-ptt start
#   bindsym --release XF86Launch5 exec llm-dictate-ptt stop

STATE_DIR="${XDG_RUNTIME_DIR:-${XDG_STATE_HOME:-$HOME/.local/state}}/llm-dictate"
REC_FILE="$STATE_DIR/llm-dictate.mp3"
REC_PIDFILE="$STATE_DIR/ffmpeg.pid"
WORKER_PIDFILE="$STATE_DIR/worker.pid"
SPINNER_PIDFILE="$STATE_DIR/spinner.pid"
NOTIFY_IDFILE="$STATE_DIR/notification.id"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

mkdir -p "$STATE_DIR"

# shellcheck source=./llm-desktop-shared.sh
source "$SCRIPT_DIR/llm-desktop-shared.sh"
notify_init "llm-dictate" "$NOTIFY_IDFILE"

is_running_pidfile() {
    local pidfile="$1"

    if [ ! -f "$pidfile" ]; then
        return 1
    fi

    kill -0 "$(cat "$pidfile")" 2>/dev/null
}

recording_active() {
    if is_running_pidfile "$REC_PIDFILE"; then
        return 0
    fi

    rm -f "$REC_PIDFILE"
    return 1
}

kill_from_pidfile() {
    local pidfile="$1"
    local signal="$2"

    if is_running_pidfile "$pidfile"; then
        kill "$signal" "$(cat "$pidfile")" 2>/dev/null
    fi

    rm -f "$pidfile"
}

stop_spinner_with_pidfile() {
    if [ -z "${SPINNER_PID:-}" ] && [ -f "$SPINNER_PIDFILE" ]; then
        SPINNER_PID="$(cat "$SPINNER_PIDFILE")"
    fi
    stop_spinner
    rm -f "$SPINNER_PIDFILE"
}

start_spinner_with_pidfile() {
    start_spinner "$1"
    if [ -n "${SPINNER_PID:-}" ]; then
        printf '%s' "$SPINNER_PID" > "$SPINNER_PIDFILE"
    fi
}

start() {
    # Ignore repeated key press events while already recording.
    if recording_active; then
        return 0
    fi

    # Ignore start requests while a previous transcription is still running.
    if is_running_pidfile "$WORKER_PIDFILE"; then
        return 0
    fi

    rm -f "$REC_FILE"

    start_spinner_with_pidfile "🎤 Recording"

    # Save up to 10 mins. Minimize buffering (-flush_packets/-avioflags) so
    # the file is valid and complete as soon as ffmpeg is killed.
    ffmpeg -f pulse -i default -ar 16000 -ac 1 -t 600 -y \
        -c:a libmp3lame -q:a 2 \
        -flush_packets 1 -avioflags direct \
        -loglevel quiet "$REC_FILE" &
    echo $! > "$REC_PIDFILE"
}

stop() {
    # Ignore repeated release events while transcription is already running.
    if is_running_pidfile "$WORKER_PIDFILE"; then
        return 0
    fi

    if ! recording_active; then
        return 0
    fi

    # Send SIGTERM so ffmpeg finalizes the MP3 file, then wait for it to exit.
    local ffmpeg_pid
    ffmpeg_pid="$(cat "$REC_PIDFILE")"
    kill -TERM "$ffmpeg_pid" 2>/dev/null
    rm -f "$REC_PIDFILE"
    while kill -0 "$ffmpeg_pid" 2>/dev/null; do
        sleep 0.05
    done

    # Launch transcription in background
    (
        local transcript
        local transcribe_err_file
        local transcribe_err_msg
        local had_error=0

        cleanup_worker() {
            [ -n "${transcribe_err_file:-}" ] && rm -f "$transcribe_err_file"
            rm -f "$REC_FILE"
            stop_spinner_with_pidfile
        }
        trap cleanup_worker EXIT

        start_spinner_with_pidfile "⏳ Transcribing"

        transcribe_err_file="$(mktemp "$STATE_DIR/transcribe.XXXXXX.err")"

        if transcript="$(llm groq-whisper - < "$REC_FILE" 2>"$transcribe_err_file")"; then
            if [ -n "$transcript" ]; then
                clipboard_paste_via_shift_insert "$transcript"
            fi
        else
            had_error=1
            stop_spinner_with_pidfile
            transcribe_err_msg="$(format_error_message "$(cat "$transcribe_err_file")")"
            notify_message "❌ Transcription failed: $transcribe_err_msg" 6000
        fi

        rm -f "$transcribe_err_file"
        stop_spinner_with_pidfile
        if [ "$had_error" -eq 0 ]; then
            close_notification
        fi
        rm -f "$WORKER_PIDFILE"
    ) &
    echo $! > "$WORKER_PIDFILE"
}

cancel() {
    if ! recording_active && ! is_running_pidfile "$WORKER_PIDFILE"; then
        echo "No recording or transcription in progress"
        return 0
    fi

    kill_from_pidfile "$REC_PIDFILE" -TERM
    kill_from_pidfile "$WORKER_PIDFILE" -TERM
    stop_spinner_with_pidfile
    rm -f "$REC_FILE"
    notify_message "🛑 Cancelled" 1000
    (sleep 1; close_notification) & disown
}

status() {
    if recording_active || is_running_pidfile "$WORKER_PIDFILE"; then
        echo "working"
    else
        echo "idle"
    fi
}

usage() {
    cat <<'EOF'
Usage: llm-dictate-ptt <command>

Commands:
  start   Start recording (bind to key press)
  stop    Stop recording and transcribe (bind to key release)
  cancel  Cancel recording or transcription in progress
  status  Show status (idle or working)

Example sway/i3 bindings:
  bindsym XF86Launch5 exec llm-dictate-ptt start
  bindsym --release XF86Launch5 exec llm-dictate-ptt stop
EOF
}

if ! require_commands ffmpeg llm ydotool dunstify; then
    dunstify --appname "llm-dictate" --timeout 6000 "llm-dictate" "❌ Missing dependencies" >/dev/null 2>&1 || true
    printf 'Install the missing commands and retry.\n' >&2
    exit 1
fi

if ! detect_clipboard_tool; then
    printf 'Missing dependencies: wl-copy and wl-paste\n' >&2
    dunstify --appname "llm-dictate" --timeout 6000 "llm-dictate" "❌ Missing dependencies: wl-copy and wl-paste" >/dev/null 2>&1 || true
    printf 'Install wl-clipboard and retry.\n' >&2
    exit 1
fi

command=""

while [ "$#" -gt 0 ]; do
    case "$1" in
        start|stop|cancel|status)
            if [ -n "$command" ]; then
                echo "Only one command can be provided" >&2
                exit 1
            fi
            command="$1"
            ;;
        -h|--help|help)
            command="help"
            ;;
        *)
            echo "Unknown argument: $1" >&2
            usage
            exit 1
            ;;
    esac
    shift
done

case "$command" in
    start)
        start
        ;;
    stop)
        stop
        ;;
    cancel)
        cancel
        ;;
    status)
        status
        ;;
    ""|help)
        usage
        ;;
    *)
        usage
        exit 1
        ;;
esac
